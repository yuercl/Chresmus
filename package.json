{
  "name": "chresmus",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:remote": "node scripts/dev.mjs --remote",
    "server": "pnpm --filter @chresmus/server dev:remote",
    "build": "pnpm -r --if-present build",
    "start": "node scripts/start.mjs",
    "start:prod": "pnpm run start",
    "test": "pnpm -r --if-present test",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm -r --if-present typecheck",
    "prepare:workspace-dist": "pnpm --filter @chresmus/unified-surface --filter @chresmus/protocol --filter @chresmus/opencode-api --filter @chresmus/api build",
    "verify:no-cheats": "node scripts/verify-no-cheats.mjs",
    "verify:no-provider-ui-imports": "node scripts/verify-no-provider-imports-in-ui.mjs",
    "verify:codex-generated": "node scripts/verify-codex-generated-clean.mjs",
    "verify:opencode-generated": "node scripts/verify-opencode-generated-clean.mjs",
    "verify:strict": "pnpm run verify:no-cheats && pnpm run verify:no-provider-ui-imports && pnpm run prepare:workspace-dist && pnpm run typecheck && pnpm run test && pnpm run verify:codex-generated && pnpm run verify:opencode-generated",
    "sanitize:traces": "node scripts/sanitize-traces.mjs",
    "generate:codex-schema": "node scripts/generate-codex-schema.mjs",
    "generate:opencode-manifest": "node scripts/generate-opencode-manifest.mjs",
    "screenshot:codex": "node skills/codex-window-debug/tools/codex-window-screenshot.mjs",
    "tauri:dev": "pnpm --filter @chresmus/tauri dev",
    "tauri:build": "pnpm --filter @chresmus/tauri build",
    "macos:build": "pnpm --filter @chresmus/tauri macos:build",
    "ios:init": "pnpm --filter @chresmus/tauri ios:init",
    "ios:build": "pnpm --filter @chresmus/tauri ios:build",
    "android:init": "pnpm --filter @chresmus/tauri android:init",
    "android:build": "pnpm --filter @chresmus/tauri android:build"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
